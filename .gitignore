models/*.bin
models/*.ggml
models/*.gguf
# whisper models downloaded by the user
*.bin

# ─── Runtime data (user-specific, never committed) ───────────────────────────
atlas_memory/
atlas_inbox/
user_voice_templates/
*.db
*.db-shm
*.db-wal

# ─── Logs ─────────────────────────────────────────────────────────────────────
