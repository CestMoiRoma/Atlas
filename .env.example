# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:27b

# ─── Ollama generation parameters ─────────────────────────────────────────────
# Leave a value empty to use the model's built-in default.
# Values below are sensible defaults for conversational use.

# temperature      Randomness (0.0–2.0). Lower = more focused.
OLLAMA_TEMPERATURE=1
# top_p            Nucleus sampling cutoff (0.0–1.0).
OLLAMA_TOP_P=0.95
# top_k            Vocab limited to top-K tokens (integer).
OLLAMA_TOP_K=64
# num_ctx          Context window size in tokens.
OLLAMA_NUM_CTX=8192
# repeat_penalty   Penalise recently used tokens (1.0 = off).
OLLAMA_REPEAT_PENALTY=1.1
# repeat_last_n    How many tokens back to apply repeat_penalty.
OLLAMA_REPEAT_LAST_N=64
# min_p            Minimum probability relative to top token (0.0–1.0).
OLLAMA_MIN_P=0.0
# num_predict      Max tokens to generate per response (-1 = unlimited).
OLLAMA_NUM_PREDICT=-1
# tfs_z            Tail-free sampling z parameter (1.0 = off).
OLLAMA_TFS_Z=1.0
# typical_p        Locally typical sampling p (1.0 = off).
OLLAMA_TYPICAL_P=1.0
# seed             RNG seed for reproducibility (-1 = random).
OLLAMA_SEED=-1

# ─── STT — whisper.cpp ────────────────────────────────────────────────────────
# Path to the whisper-cli binary (brew install whisper-cpp)
WHISPER_CPP_BIN=whisper-cli
# Absolute path to a GGML model file.
# Download from: https://huggingface.co/ggerganov/whisper.cpp/tree/main
# Recommended: ggml-large-v3-turbo.bin (~800 MB)
WHISPER_CPP_MODEL=/path/to/ggml-large-v3-turbo.bin
# BCP-47 language code — skip auto-detection for faster, more accurate results
WHISPER_CPP_LANGUAGE=fr
# no_speech_prob threshold: transcriptions with a higher probability of silence
# are discarded silently. Fixes whisper hallucinations in near-silence. (0.0–1.0)
WHISPER_NO_SPEECH_THRESHOLD=0.6

# ─── TTS — macOS native `say` ─────────────────────────────────────────────────
# Speaking rate in words per minute (leave empty for system default ~175 wpm)
TTS_RATE=

# ─── Wake Word — livekit-wakeword ─────────────────────────────────────────────
# Path to the ONNX wakeword model, relative to the project root.
# Atlas.onnx is included in the repo under models/.
WAKE_WORD_MODELS=models/Atlas.onnx
# Detection confidence threshold (0.0–1.0). Lower = more sensitive (more false positives).
WAKE_WORD_THRESHOLD=0.5
# Minimum seconds before the same word can fire again (debounce).
WAKE_WORD_DEBOUNCE=2.0

# ─── Audio — recording ────────────────────────────────────────────────────────
# sounddevice input device index (-1 = system default)
AUDIO_INPUT_DEVICE=-1
# Sample rate in Hz
AUDIO_SAMPLE_RATE=16000

# ─── VAD — Voice Activity Detection ──────────────────────────────────────────
# RMS energy threshold to distinguish speech from silence (0–32767).
# Raise this value if you get many phantom transcriptions in quiet environments.
VAD_ENERGY_THRESHOLD=300
# Seconds to wait for the user to begin speaking before aborting the recording.
VAD_SPEECH_TIMEOUT=8.0
# Seconds of trailing silence after speech before stopping the recording.
VAD_SILENCE_AFTER=1.2
# Hard cap on recording length in seconds.
VAD_MAX_DURATION=30.0

# ─── Document Inbox ───────────────────────────────────────────────────────────
# Drop files here and ask Atlas to read them. Supported: .txt .md .json .csv .tsv .drawio .xml
# Files are never deleted — Atlas can re-read them at any time.
ATLAS_INBOX_PATH=./atlas_inbox

# ─── Memory — Obsidian vault ──────────────────────────────────────────────────
# Root path of the Obsidian vault Atlas reads and writes.
ATLAS_VAULT_PATH=./atlas_memory

# ─── MCP Tool Servers ─────────────────────────────────────────────────────────
# Python interpreter used when spawning tool server subprocesses.
MCP_PYTHON=python3
# Per-tool call timeout in seconds. Tools that hang are aborted and return an error.
MCP_TOOL_TIMEOUT=10.0

# ─── Speaker Identification ───────────────────────────────────────────────────
# Path to the SQLite database that stores user profiles and voice embeddings.
SPEAKER_DB_PATH=./atlas_users.db
# Directory where confirmed voice samples are saved per user for embedding re-averaging.
VOICE_TEMPLATES_DIR=./user_voice_templates
# Re-average the embedding after every N new saved samples.
EMBED_UPDATE_EVERY=5
# Maximum WAV files to keep per user (oldest deleted first).
MAX_SAMPLES_PER_USER=50
# Cosine similarity threshold for accepting a speaker match (0.0–1.0).
# 0.70 works well after a single-sample registration; raise to 0.80+ after
# several sessions of sleeping-mode re-averaging.
SPEAKER_ID_THRESHOLD=0.75
# Soft fallback floor: if score >= this but < SPEAKER_ID_THRESHOLD, fall back
# to the last known user rather than treating the voice as a stranger.
SPEAKER_FALLBACK_MIN_SCORE=0.30
# SpeechBrain HuggingFace model ID for ECAPA-TDNN speaker embeddings.
SPEAKER_MODEL=speechbrain/spkrec-ecapa-voxceleb
# Local cache directory for downloaded SpeechBrain weights.
SPEAKER_SAVEDIR=./models/spkrec-ecapa-voxceleb

# ─── Sleeping Mode ────────────────────────────────────────────────────────────
# Seconds of inactivity before sleeping mode triggers:
#   • closes the current session log
#   • re-averages all user voice embeddings from accumulated samples
#   • opens a fresh session log for the next conversation
SLEEP_TIMEOUT=180

# ─── Logging ──────────────────────────────────────────────────────────────────
# Path for the debug log (DEBUG level, rotating 10 MB × 3 files).
# Leave empty to disable file logging (terminal output only).
LOG_FILE=atlas_debug.log

# ─── Thinking ─────────────────────────────────────────────────────────────────
# Set to true to disable chain-of-thought / thinking tokens.
# Equivalent to launching with --nothink. Recommended for voice use.
NOTHINK=false
# Thinking depth hint injected into the system prompt when thinking is enabled.
# Gemma 4 has no token-budget API via Ollama — this prompt instruction is the only lever.
# Values: court (fast) | modéré (default) | approfondi (slow, thorough)
# Leave empty to disable the hint.
THINK_DEPTH=modéré

# ─── Tool Loop ────────────────────────────────────────────────────────────────
# Maximum consecutive tool-call rounds per turn before Atlas gives up.
# Raise if complex workflows legitimately chain many tools; lower for faster failure.
MAX_TOOL_ROUNDS=10
